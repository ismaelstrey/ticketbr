generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum TicketStatus {
  TODO
  DOING
  PAUSED
  DONE
}

enum TicketPriority {
  HIGH
  MEDIUM
  NONE
}

enum TicketEventType {
  CREATED
  STATUS_CHANGED
  PAUSED
  COMMENT
  NOTE
  ASSIGNED
  SLA_UPDATED
  UPDATED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum Role {
  ADMIN
  AGENT
  CUSTOMER
}

// Existing User model - keeping for backward compatibility or future migration
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String   @default("default_hash")
  role      Role     @default(AGENT)
  whatsappId     String?  @unique
  remoteJid      String?  @db.Text
  pushName       String?
  profilePicUrl  String?  @db.Text
  instanceId     String?
  funcionario    Funcionario?
  tickets   Ticket[] @relation("OperatorTickets")
  events    TicketEvent[]
  createdTickets Ticket[] @relation("TicketCreatedBy")

  createdTasks Task[] @relation("TaskCreatedBy")
  assignedTasks Task[] @relation("TaskAssignee")
  createdTaskAttachments TaskAttachment[] @relation("TaskAttachmentCreatedBy")

  ownedProjects Project[] @relation("ProjectOwner")
  projectMemberships ProjectMember[]
  projectExports ProjectExportAudit[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WhatsAppContact {
  id            String   @id
  funcionarios   Funcionario[]
  remoteJid     String   @map("remote_jid") @db.Text
  pushName      String?  @map("push_name")
  profilePicUrl String?  @map("profile_pic_url") @db.Text
  createdAt     DateTime @map("created_at")
  updatedAt     DateTime @map("updated_at")
  instanceId    String?  @map("instance_id")
  syncedAt      DateTime @default(now()) @map("synced_at")

  @@index([remoteJid])
  @@index([instanceId])
  @@map("whatsapp_contacts")
}

model Solicitante {
  id               String   @id @default(cuid())
  razao_social     String   @db.VarChar(255)
  nome_fantasia    String   @db.VarChar(255)
  cnpj             String   @unique @db.VarChar(14)
  email            String   @db.VarChar(255)
  telefone         String   @db.VarChar(20)
  endereco_completo String   @db.Text
  data_cadastro    DateTime @default(now())
  status           Boolean  @default(true)
  
  // Audit fields
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  created_by       String?
  updated_by       String?
  deleted_at       DateTime?

  funcionarios     Funcionario[]
  tickets          Ticket[]

  @@index([cnpj])
  @@index([email])
  @@index([telefone])
}

model Funcionario {
  id             String      @id @default(cuid())
  solicitante_id String
  solicitante    Solicitante @relation(fields: [solicitante_id], references: [id], onDelete: Restrict)

  userId         String      @unique
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  nome           String      @db.VarChar(255)
  email          String?     @db.VarChar(255)
  telefone       String      @db.VarChar(20)

  whatsappId       String?          @unique
  remoteJid        String?          @db.Text
  pushName         String?
  profilePicUrl    String?          @db.Text
  instanceId       String?
  whatsappContactId String?         @map("whatsapp_contact_id")
  whatsappContact  WhatsAppContact? @relation(fields: [whatsappContactId], references: [id], onDelete: SetNull)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  isAdmin        Boolean     @default(false) @map("is_admin")

  @@unique([solicitante_id, telefone])
  @@index([solicitante_id])
  @@index([telefone])
  @@index([whatsappContactId])
}

model AuditLog {
  id            String   @id @default(cuid())
  solicitanteId String?  @map("solicitante_id")
  actorUserId   String?  @map("actor_user_id")
  action        String
  entity        String
  entityId      String?  @map("entity_id")
  metadata      Json?    @map("metadata")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([solicitanteId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model Tipo_Ticket {
  id                String   @id @default(cuid())
  nome              String   @unique @db.VarChar(100)
  descricao         String   @db.Text
  sla_horas         Int
  prioridade_default String   @db.VarChar(20)
  status            Boolean  @default(true)
  
  // Audit fields
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  created_by        String?
  updated_by        String?
  deleted_at        DateTime?

  categorias        Categoria_Ticket[]
  tickets           Ticket[]
}

model Categoria_Ticket {
  id             String      @id @default(cuid())
  tipo_ticket_id String
  tipo_ticket    Tipo_Ticket @relation(fields: [tipo_ticket_id], references: [id], onDelete: Restrict)
  nome           String      @db.VarChar(100)
  descricao      String      @db.Text
  status         Boolean     @default(true)
  
  // Audit fields
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  created_by     String?
  updated_by     String?
  deleted_at     DateTime?

  tickets        Ticket[]

  @@unique([tipo_ticket_id, nome])
}

model Mesa_Trabalho {
  id             String    @id @default(cuid())
  nome           String    @db.VarChar(100)
  localizacao    String    @db.VarChar(255)
  capacidade     Int
  responsavel_id String?
  responsavel    Operador? @relation("MesaResponsavel", fields: [responsavel_id], references: [id], onDelete: SetNull)
  status         Boolean   @default(true)
  tipo           String    @db.VarChar(50)
  
  // Audit fields
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  created_by     String?
  updated_by     String?
  deleted_at     DateTime?

  operadores     Operador[] @relation("MesaOperadores")
  tickets        Ticket[]
}

model Operador {
  id               String   @id @default(cuid())
  nome             String   @db.VarChar(255)
  email            String   @unique @db.VarChar(255)
  senha_hash       String   @db.VarChar(255)
  matricula        String   @unique @db.VarChar(50)
  perfil           String   @db.VarChar(50)
  mesa_trabalho_id String?
  mesa_trabalho    Mesa_Trabalho? @relation("MesaOperadores", fields: [mesa_trabalho_id], references: [id], onDelete: SetNull)
  is_tecnico       Boolean  @default(true)
  is_active        Boolean  @default(true)
  ultimo_acesso    DateTime?
  especialidade    String?  @db.VarChar(100)
  
  // Audit fields
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  created_by       String?
  updated_by       String?
  deleted_at       DateTime?

  mesas_responsaveis Mesa_Trabalho[] @relation("MesaResponsavel")
  tickets            Ticket[]
}

model Ticket {
  id            String         @id @default(cuid())
  number        Int            @unique @default(autoincrement())
  
  // New relationships
  solicitante_id String?
  solicitante    Solicitante? @relation(fields: [solicitante_id], references: [id], onDelete: Restrict)
  
  tipo_ticket_id String?
  tipo_ticket    Tipo_Ticket? @relation(fields: [tipo_ticket_id], references: [id], onDelete: Restrict)
  
  categoria_id   String?
  categoria      Categoria_Ticket? @relation(fields: [categoria_id], references: [id], onDelete: Restrict)
  
  mesa_trabalho_id String?
  mesa_trabalho_rel Mesa_Trabalho? @relation(fields: [mesa_trabalho_id], references: [id], onDelete: Restrict)
  
  operador_id    String?
  operador_rel   Operador? @relation(fields: [operador_id], references: [id], onDelete: Restrict)

  // Legacy fields (keeping for compatibility/migration or plain text storage if relation not available)
  company       String?
  requester     String?
  subject       String
  description   String?
  status        TicketStatus   @default(TODO)
  priority      TicketPriority @default(NONE)
  
  operator      String?
  
  // Relation to User model (Legacy)
  operatorId    String?
  operatorUser  User?          @relation("OperatorTickets", fields: [operatorId], references: [id])

  createdByUserId String?
  createdByUser   User?        @relation("TicketCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  
  contact       String?
  ticketType    String? // Legacy string field
  category      String? // Legacy string field
  workbench     String? // Legacy string field
  responseSlaAt DateTime?
  solutionSlaAt DateTime?
  pausedReason  String?
  pauseSla      Boolean        @default(false)
  pausedStartedAt DateTime?
  pausedTotalSeconds Int       @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  // Audit fields
  created_by    String?
  updated_by    String?
  deleted_at    DateTime?

  events        TicketEvent[]
  chatConversations ChatConversation[]

  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([solicitante_id])
  @@index([createdByUserId])
}

model TicketEvent {
  id          String          @id @default(cuid())
  ticketId    String
  ticket      Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  type        TicketEventType
  title       String
  description String?
  fromStatus  TicketStatus?
  toStatus    TicketStatus?
  pauseReason String?
  metadata    Json?
  
  // Legacy string field
  author      String?
  
  // Relation to User model
  authorId    String?
  authorUser  User?           @relation(fields: [authorId], references: [id])
  
  createdAt   DateTime        @default(now())

  @@index([ticketId, createdAt])
  @@index([type])
}


model ChatConversation {
  id             String   @id @default(cuid())
  contactId      String
  contactName    String
  channel        String
  conversationId String
  ticketId       String?
  ticket         Ticket?  @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  messages       Json
  finalized      Boolean  @default(false)
  closedAt       DateTime @default(now())
  nextStartedAt  DateTime?
  createdBy      String?

  @@index([contactId, channel, finalized, closedAt])
  @@index([contactId, channel, nextStartedAt])
  @@index([ticketId])
}

model Conversation {
  id              String    @id @default(cuid()) // conversation_id
  waChatId        String    @unique @map("wa_chat_id") // JID do WhatsApp
  instance        String?
  status          String    @default("open") // open, closed
  botActive       Boolean   @default(true) @map("bot_active")
  humanActive     Boolean   @default(false) @map("human_active")
  assignedTo      String?   @map("assigned_to") // userId
  lastMessageAt   DateTime? @map("last_message_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  messages        Message[]

  @@map("conversations")
}

model Message {
  id              String    @id @default(cuid())
  waMessageId     String?   @unique @map("wa_message_id")
  conversationId  String    @map("conversation_id")
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  direction       String    // in, out
  type            String    // text, image, audio, etc.
  body            String?   @db.Text // text or caption
  mediaUrl        String?   @map("media_url")
  mimetype        String?
  status          String    @default("sent") // sent, delivered, read
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("messages")
}

model Task {
  id           String       @id @default(cuid())
  title        String       @db.VarChar(180)
  description  String?      @db.Text
  priority     TaskPriority @default(MEDIUM)
  status       TaskStatus   @default(PENDING)
  sortOrder    Float        @default(0) @map("sort_order")
  dueAt        DateTime?    @map("due_at")
  completedAt  DateTime?    @map("completed_at")

  assigneeId   String?      @map("assignee_id")
  assignee     User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  createdById  String       @map("created_by_id")
  createdBy    User         @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  subtasks     TaskSubtask[]
  attachments  TaskAttachment[]
  ticketLinks  TaskTicketLink[]

  @@index([status, sortOrder])
  @@index([dueAt])
  @@index([assigneeId])
  @@index([createdById])
}

model TaskSubtask {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title     String   @db.VarChar(220)
  isDone    Boolean  @default(false) @map("is_done")
  sortOrder Float    @default(0) @map("sort_order")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId, sortOrder])
}

model TaskAttachment {
  id          String   @id @default(cuid())
  taskId      String   @map("task_id")
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileName    String   @map("file_name")
  mimeType    String?  @map("mime_type")
  fileSize    Int?     @map("file_size")
  data        Bytes
  createdById String   @map("created_by_id")
  createdBy   User     @relation("TaskAttachmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())

  @@index([taskId])
}

model TaskTicketLink {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  ticketId  String   @map("ticket_id")
  createdAt DateTime @default(now())

  @@unique([taskId, ticketId])
  @@index([ticketId])
}

model Project {
  id          String        @id @default(cuid())
  name        String        @db.VarChar(180)
  description String?       @db.Text
  status      ProjectStatus @default(ACTIVE)

  ownerUserId String        @map("owner_user_id")
  ownerUser   User          @relation("ProjectOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)

  startDate   DateTime?     @db.Date @map("start_date")
  endDate     DateTime?     @db.Date @map("end_date")
  archivedAt  DateTime?     @map("archived_at")

  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  members     ProjectMember[]
  exports     ProjectExportAudit[]

  @@index([status, createdAt])
  @@index([ownerUserId, createdAt])
  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  role      String   @default("member")
  createdAt DateTime @default(now()) @map("created_at")

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId, createdAt])
  @@index([userId, createdAt])
  @@map("project_members")
}

model ProjectExportAudit {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  projectId String?  @map("project_id")
  format    String
  filters   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@map("project_export_audit")
}
