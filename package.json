{
  "name": "ticketbr",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "postbuild": "node scripts/postbuild.cjs",
    "start": "next start",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:contract": "vitest run src/test/contracts",
    "test:watch": "vitest",
    "postinstall": "node -e \"const fs=require('fs'); const cp=require('child_process'); const schema='prisma/schema.prisma'; if(fs.existsSync(schema)){ cp.execSync('npx prisma generate',{stdio:'inherit'});} else { console.warn('Skipping prisma generate: '+schema+' not found'); }\"",
    "db:migrate": "node scripts/db-migrate.cjs",
    "db:migrate:prod": "node scripts/db-migrate.cjs",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:push": "node scripts/db-push.cjs",
    "seed": "tsx prisma/seed.ts",
    "db:seed": "node scripts/db-seed.cjs",
    "db:deploy": "node scripts/db-deploy.cjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/client-sts": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@faker-js/faker": "^9.9.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/adapter-ppg": "^7.4.1",
    "@prisma/client": "^7.7.0",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.34.1",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.3",
    "libphonenumber-js": "^1.12.38",
    "next": "16.1.6",
    "nodemailer": "^6.10.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.18.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.2.0",
    "remark-gfm": "^4.0.1",
    "s3rver": "^3.7.1",
    "styled-components": "^6.3.9",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "25.2.3",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.16.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/styled-components": "^5.1.36",
    "eslint": "^4.1.1",
    "eslint-config-next": "^0.2.4",
    "jsdom": "^28.1.0",
    "prisma": "^7.7.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  }
}
